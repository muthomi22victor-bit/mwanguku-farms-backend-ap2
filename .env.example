# ==========================================
# MWANGUKU FARMS LTD — ENVIRONMENT VARIABLES
# Copy this file to ".env" and fill in real values.
# NEVER commit your actual .env file to version control.
# ==========================================

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Get this from Atlas: Database > Connect > Drivers
# Replace <username>, <password>, and <dbname>
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/mwanguku-farms?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Admin account created by seed.js
ADMIN_NAME=Mwanguku Farms Admin
ADMIN_EMAIL=admin@mwangukufarms.co.ke
ADMIN_PASSWORD=SecureAdmin2026

# CORS — comma-separated list of allowed frontend origins
# Example: https://mwangukufarms.netlify.app,https://mwangukufarms.co.ke
CLIENT_URL=https://mwangukufarms.netlify.app
